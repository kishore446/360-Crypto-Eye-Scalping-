# ══════════════════════════════════════════════════════════
# 360 Crypto Eye Scalping — VPS Production Configuration
# ══════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then edit with your values: nano .env
# ══════════════════════════════════════════════════════════

# ── Telegram (REQUIRED) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_CHAT_ID=your_telegram_user_id

# ── CoinMarketCal (optional, recommended for news filter)
COINMARKETCAL_API_KEY=your_api_key

# ── Webhook Security ─────────────────────────────────────
WEBHOOK_SECRET=generate_a_strong_random_secret_here
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000
# Comma-separated IPs allowed to call webhook (empty = all)
ALLOWED_WEBHOOK_IPS=
WEBHOOK_RATE_LIMIT_WINDOW=60
WEBHOOK_RATE_LIMIT_MAX=30

# ── Persistence (use data/ prefix for Docker volume) ─────
SIGNALS_FILE=data/signals.json
DASHBOARD_LOG_FILE=data/dashboard.json
DB_PATH=data/360eye.db

# ── Auto-Scanner ─────────────────────────────────────────
# Leave empty to auto-discover ALL Binance Futures USDT-M pairs (200+)
AUTO_SCAN_PAIRS=
AUTO_SCAN_INTERVAL_SECONDS=300
# Auto-scan starts ON by default — set to false for manual /auto_scan
AUTO_SCAN_ENABLED_ON_BOOT=true

# ── Signal Engine ────────────────────────────────────────
LEVERAGE_MIN=10
LEVERAGE_MAX=20
DEFAULT_RISK_FRACTION=0.01
TP1_RR=1.5
TP2_RR=2.5
TP3_RR=4.0

# ── Safety Protocols ─────────────────────────────────────
MAX_SAME_SIDE_SIGNALS=3
STALE_SIGNAL_HOURS=4
BE_TRIGGER_FRACTION=0.50

# ── News Filter ──────────────────────────────────────────
NEWS_SKIP_WINDOW_MINUTES=60
