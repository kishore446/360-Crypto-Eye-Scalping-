# ──────────────────────────────────────────────
# 360 Crypto Eye — VPS Production Configuration
# ──────────────────────────────────────────────

# ── Telegram (REQUIRED) ──────────────────────
TELEGRAM_BOT_TOKEN=8283071995:AAHnpChFpunWwn0UwLLdVez-1o15qPfN6GM
ADMIN_CHAT_ID=710718010

# ── Multi-Channel Telegram ────────────────────────────────────────────────────
# CH1: Scalping — if not set, falls back to TELEGRAM_CHANNEL_ID
TELEGRAM_CHANNEL_ID_SCALPING=-1003851389127
# CH2: Intraday / Swing — set to 0 or omit to disable this channel
TELEGRAM_CHANNEL_ID_INTRADAY=-1003705465763
# CH3: Trend / Positional — set to 0 or omit to disable this channel
TELEGRAM_CHANNEL_ID_TREND=-1003736541473
# CH4: Spot Momentum — set to 0 or omit to disable this channel
TELEGRAM_CHANNEL_ID_SPOT=-1003359307432
# CH5: Market Insights — set to 0 or omit to disable this channel
TELEGRAM_CHANNEL_ID_INSIGHTS=-1003711338895
# CH6: Altcoin Gems — Low-cap DCA/swing signals
TELEGRAM_CHANNEL_ID_ALTGEMS=-1003775779519
# CH7: Whale Tracker — Dedicated whale movement + liquidation alerts
TELEGRAM_CHANNEL_ID_WHALE=-1003857912727
# CH8: Education — Post-trade reviews, pattern education
TELEGRAM_CHANNEL_ID_EDUCATION=-1003871046468
# CH9: VIP Discussion — Member analysis & discussion
TELEGRAM_CHANNEL_ID_VIP=-1003345623558
# ── Channel Thresholds ───────────────────────────────────────────────────────
CH2_NEWS_WINDOW_MINUTES=30
CH3_VOLUME_SPIKE_RATIO=1.5
CH4_SCAN_INTERVAL_HOURS=4
CH4_ACCUMULATION_THRESHOLD=0.15

# ── Insights ─────────────────────────────────────────────────────────────────
BTC_FEAR_GREED_URL=https://api.alternative.me/fng/
REGIME_DETECTOR_ENABLED=true

# ── Signal Deduplication ─────────────────────────────────────────────────────
# Suppress CH2/CH3 if the same symbol fired on CH1 within this window
DEDUP_WINDOW_MINUTES=15

# ── CoinMarketCal (optional, recommended for news filtering) ──
COINMARKETCAL_API_KEY=e6JNtDcu295JKPGEmqiy44O5onWzoABJ2Lb6gSqK

# ── Webhook Security ─────────────────────────
WEBHOOK_SECRET=generate_a_strong_random_secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000

# ── Persistence ──────────────────────────────
# Paths are relative to /app inside the container (mapped to the 360eye-data volume)
SIGNALS_FILE=data/signals.json
DASHBOARD_LOG_FILE=data/dashboard.json
DB_PATH=data/360eye.db

# ── Auto-Scanner ─────────────────────────────
# Leave empty to scan ALL Binance Futures USDT-M pairs (recommended).
# Set to a comma-separated list to use as a whitelist override (e.g. for testing).
# AUTO_SCAN_PAIRS=BTC,ETH,SOL,XRP,DOGE
AUTO_SCAN_PAIRS=
# Reduced from 300s to 60s for faster recovery from WebSocket degradation
AUTO_SCAN_INTERVAL_SECONDS=60
AUTO_SCAN_ENABLED_ON_BOOT=true

# ── Futures Scanner Tuning ────────────────────────────────────────────────────
# Optional: skip pairs with less than this 24h USD volume (0 = no filter, scan all)
FUTURES_MIN_24H_VOLUME_USDT=0
FUTURES_SCAN_BATCH_SIZE=20
FUTURES_SCAN_BATCH_DELAY=0.5

# ── Spot Scanner ──────────────────────────────────────────────────────────────
# Enable gem detection and scam alerting for Binance Spot pairs → CH4/CH5
SPOT_SCAN_ENABLED=true
SPOT_SCAN_INTERVAL_MINUTES=60
SPOT_MIN_24H_VOLUME_USDT=100000
SPOT_GEM_VOLUME_SPIKE_RATIO=3.0
SPOT_GEM_BREAKOUT_LOOKBACK_DAYS=30
SPOT_GEM_ACCUMULATION_RANGE_PCT=0.10
SPOT_NEW_LISTING_LOOKBACK_DAYS=90
SPOT_SCAM_PUMP_THRESHOLD_PCT=500.0
SPOT_SCAM_CRASH_THRESHOLD_PCT=50.0
SPOT_SCAN_BATCH_SIZE=30
SPOT_SCAN_BATCH_DELAY=0.5

# ── Safety Protocols ─────────────────────────
# Blueprint v3 sets max 3 concurrent same-side signals
MAX_SAME_SIDE_SIGNALS=3
STALE_SIGNAL_HOURS=4

# ── Signal Engine ────────────────────────────
LEVERAGE_MIN=10
LEVERAGE_MAX=20
TP1_RR=1.5
TP2_RR=2.5
TP3_RR=4.0

# ── News Filter ──────────────────────────────
NEWS_SKIP_WINDOW_MINUTES=60

# ── Session Filter ────────────────────────────────────────────────
# Enabled by default — restricts CH1/CH2 signals to liquid London + NYC sessions
SESSION_FILTER_ENABLED=true
# Per-channel session gating (CH1/CH2 gated, CH3/CH4 24/7)
SESSION_FILTER_CH1_ENABLED=true
SESSION_FILTER_CH2_ENABLED=true
SESSION_FILTER_CH3_ENABLED=false
SESSION_FILTER_CH4_ENABLED=false

# ── Confluence Scoring ────────────────────────────────────────────
# 40 = minimum score to avoid noise (Blueprint recommendation)
MIN_CONFLUENCE_SCORE=40

# ── Displacement Filter (Gate ④) ─────────────────────────────────
# Minimum price displacement % to confirm an MSS breakout (Blueprint §2.2)
# 0.15 = 0.15% displacement required; set to 0.0 to disable
MIN_DISPLACEMENT_PCT=0.15

# ── News Fail-Safe ────────────────────────────────────────────────
NEWS_FAIL_SAFE_WINDOW_MINUTES=60

# ── Whale Alert API (optional, for real on-chain whale tracking) ──────────────
# Get your key at https://whale-alert.io/
WHALE_ALERT_API_KEY=your_whale_alert_api_key

# ── Coinglass API (optional, for real liquidation data) ───────────────────────
# Get your key at https://coinglass.com/
COINGLASS_API_KEY=your_coinglass_api_key

# ── Signal Broadcast Rate Limiting ────────────────────────────────────────────
# Minimum gap in seconds between signal broadcasts per channel (default 5 min)
MIN_SIGNAL_GAP_SECONDS=300

# ── Admin Alerting ────────────────────────────────────────────────────────────
# Send DMs to admin when win rate drops or bot encounters issues
ADMIN_ALERT_ENABLED=true
ADMIN_ALERT_WIN_RATE_THRESHOLD=40

# ── OI Divergence Detection ───────────────────────────────────────────────────
OI_DIVERGENCE_ENABLED=true

# ── Chart Generation ─────────────────────────────────────────────────────────
CHART_ENABLED=true

# ── Daily Briefing ────────────────────────────────────────────────────────────
BRIEFING_ENABLED=true
BRIEFING_HOUR_UTC=8

# ── Invalidation Detector ─────────────────────────────────────────────────────
INVALIDATION_CHECK_ENABLED=true

# ── Correlation Guard ─────────────────────────────────────────────────────────
CORRELATION_ALERT_ENABLED=true
CORRELATION_MAX_SAME_GROUP=3

# ── DB Archiving ─────────────────────────────────────────────────────────────
DB_ARCHIVE_DAYS=90

# ── CH6 Altcoin Gems ──────────────────────────────────────────────────────────
# Set to 0 or omit to disable CH6 altcoin gems scanning
TELEGRAM_CHANNEL_ID_ALTGEMS=0
ALTGEM_SCAN_INTERVAL_HOURS=2
ALTGEM_MIN_VOLUME_SPIKE=3.0
ALTGEM_MAX_24H_VOLUME_USDT=5000000

# ── CH8 Education ─────────────────────────────────────────────────────────────
# Set to 0 or omit to disable CH8 education posts
TELEGRAM_CHANNEL_ID_EDUCATION=0
EDUCATION_LESSON_HOUR_UTC=10
EDUCATION_PATTERN_HOUR_UTC=16

# ── CH9 VIP ───────────────────────────────────────────────────────────────────
# Set to 0 or omit to disable CH9 VIP features
TELEGRAM_CHANNEL_ID_VIP=0
VIP_MAX_PORTFOLIO_ENTRIES=50
VIP_MAX_ALERTS_PER_USER=20

# ── Enhanced Insights ─────────────────────────────────────────────────────────
ALTSEASON_POST_INTERVAL_HOURS=6
SECTOR_DASHBOARD_HOUR_UTC=12
OI_HEATMAP_INTERVAL_HOURS=4
