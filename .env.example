# ──────────────────────────────────────────────
# 360 Crypto Eye — VPS Production Configuration
# ──────────────────────────────────────────────

# ── Telegram (REQUIRED) ──────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_CHAT_ID=your_telegram_user_id

# ── CoinMarketCal (optional, recommended for news filtering) ──
COINMARKETCAL_API_KEY=your_api_key

# ── Webhook Security ─────────────────────────
WEBHOOK_SECRET=generate_a_strong_random_secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000

# ── Persistence ──────────────────────────────
# Paths are relative to /app inside the container (mapped to the 360eye-data volume)
SIGNALS_FILE=data/signals.json
DASHBOARD_LOG_FILE=data/dashboard.json
DB_PATH=data/360eye.db

# ── Auto-Scanner ─────────────────────────────
# Leave AUTO_SCAN_PAIRS empty to scan ALL Binance Futures USDT-M pairs (200+)
AUTO_SCAN_PAIRS=
# Reduced from 300s to 60s for faster recovery from WebSocket degradation
AUTO_SCAN_INTERVAL_SECONDS=60
AUTO_SCAN_ENABLED_ON_BOOT=true

# ── Safety Protocols ─────────────────────────
# Raised from 3 to 5 to allow more concurrent signals during trending markets
MAX_SAME_SIDE_SIGNALS=5
STALE_SIGNAL_HOURS=4

# ── Signal Engine ────────────────────────────
LEVERAGE_MIN=10
LEVERAGE_MAX=20
TP1_RR=1.5
TP2_RR=2.5
TP3_RR=4.0

# ── News Filter ──────────────────────────────
NEWS_SKIP_WINDOW_MINUTES=60

# ── Session Filter ────────────────────────────────────────────────
# Disabled by default for 24/7 crypto scanning (includes Asia session);
# set to true to restrict signals to London + New York hours only (07:00-21:00 UTC)
SESSION_FILTER_ENABLED=false

# ── Confluence Scoring ────────────────────────────────────────────
MIN_CONFLUENCE_SCORE=0

# ── News Fail-Safe ────────────────────────────────────────────────
NEWS_FAIL_SAFE_WINDOW_MINUTES=60
