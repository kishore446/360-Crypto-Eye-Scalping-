# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_CHAT_ID=your_telegram_user_id

# CoinMarketCal (optional but recommended for news filtering)
COINMARKETCAL_API_KEY=your_api_key

# Webhook security
WEBHOOK_SECRET=your_secret_here
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000

# Persistence
SIGNALS_FILE=signals.json
DASHBOARD_LOG_FILE=dashboard.json

# Auto-scanner
AUTO_SCAN_PAIRS=BTC,ETH,SOL,XRP,DOGE,ADA,AVAX,LINK,DOT,MATIC
AUTO_SCAN_INTERVAL_SECONDS=300
